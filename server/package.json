{
  "name": "rule-generator-server",
  "version": "1.0.0",
  "type": "module",
  "description": "Express backend for Rule Generator",
  "main": "src/index.ts",
  "scripts": {
    "start": "node --loader ts-node/esm src/index.ts",
    "dev": "nodemon --exec node --loader ts-node/esm src/index.ts",
    "agent": "node --loader ts-node/esm src/run-agent.ts",
    "build": "tsc",
    "lint": "eslint src"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.84",
    "@anthropic-ai/sdk": "^0.80.0",
    "axios": "^1.13.6",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "fs-extra": "^11.3.4",
    "js-base64": "^3.7.8",
    "path": "^0.12.7",
    "simple-git": "^3.20.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "typescript": "~5.9.3"
  }
}
